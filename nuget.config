<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- <clear /> stops user-level / system NuGet.Config sources from leaking
         into this build (e.g. internal feeds with credentials). Matches the
         convention already used by Asterisk.Sdk.Pro and Asterisk.Platform and
         avoids NU1507 when central package management is on.
         The MIT SDK is the producer of the cross-repo local feed; it does
         not consume from it, so no local source is configured here. Pro
         and Platform add their own local feed entries because they consume. -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
