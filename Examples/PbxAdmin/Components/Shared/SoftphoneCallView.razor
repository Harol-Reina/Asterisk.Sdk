@namespace PbxAdmin.Components.Shared
@implements IDisposable
@inject SoftphoneService Phone

<div class="softphone-call-info">
    <div class="softphone-call-number">@(Phone.RemoteNumber ?? "Unknown")</div>
    @if (Phone.RemoteName is not null)
    {
        <div class="softphone-call-name">@Phone.RemoteName</div>
    }
    <div class="softphone-call-duration">@_duration</div>
</div>

<div class="softphone-controls">
    <button class="softphone-ctrl-btn @(Phone.IsMuted ? "muted" : "")" @onclick="Phone.ToggleMuteAsync" title="@(Phone.IsMuted ? "Unmute" : "Mute")">
        @(Phone.IsMuted ? "🔇" : "🔊")
    </button>
    <button class="softphone-ctrl-btn @(Phone.IsOnHold ? "active" : "")" @onclick="Phone.ToggleHoldAsync" title="@(Phone.IsOnHold ? "Resume" : "Hold")">
        ⏸
    </button>
    <button class="softphone-ctrl-btn" @onclick="ToggleDtmf" title="DTMF">
        🔢
    </button>
    <button class="softphone-ctrl-btn hangup" @onclick="Phone.HangupAsync" title="Hangup">
        📵
    </button>
</div>

@if (_showDtmf)
{
    <div class="softphone-dialpad" style="padding-bottom:0.5rem;">
        @foreach (var d in new[] { "1","2","3","4","5","6","7","8","9","*","0","#" })
        {
            <div class="softphone-key" @onclick="() => Phone.SendDtmfAsync(d)">@d</div>
        }
    </div>
}

@code {
    private string _duration = "00:00";
    private bool _showDtmf;
    private Timer? _timer;

    protected override void OnInitialized()
    {
        _timer = new Timer(_ =>
        {
            if (Phone.CallStartedAt is not null)
            {
                var elapsed = DateTimeOffset.UtcNow - Phone.CallStartedAt.Value;
                _duration = elapsed.ToString(@"mm\:ss");
                InvokeAsync(StateHasChanged);
            }
        }, null, 0, 1000);
    }

    private void ToggleDtmf() => _showDtmf = !_showDtmf;

    public void Dispose() => _timer?.Dispose();
}
