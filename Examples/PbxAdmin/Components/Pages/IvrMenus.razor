@page "/ivr-menus"
@using PbxAdmin.Models
@using PbxAdmin.Services
@inject IvrMenuService IvrSvc
@inject SelectedServerService ServerSvc
@inject NavigationManager Nav
@inject IStringLocalizer<SharedStrings> L

<PageTitle>@L["Ivr_Title"]</PageTitle>

<div class="page-header-row">
    <h2>@L["Ivr_Heading"]</h2>
    <button class="btn btn-primary" @onclick="NewMenu">@L["Ivr_NewIvr"]</button>
</div>

<HelpPanel SectionKey="IvrMenus_Overview">@L["Ivr_Heading"]</HelpPanel>

@if (_loading)
{
    <p>@L["Lbl_Loading"]</p>
}
else if (_menus.Count == 0)
{
    <p class="text-muted">@L["Ivr_NoMenus"]</p>
}
else
{
    <div class="card-grid">
        @foreach (var menu in _menus)
        {
            <div class="card clickable" @onclick="() => EditMenu(menu.Id)">
                <div class="card-header">
                    <strong>@menu.Label</strong>
                    @if (!menu.Enabled)
                    {
                        <span class="badge badge-muted">@L["Lbl_Disabled"]</span>
                    }
                    @if (menu.MaxDepth > 3)
                    {
                        <span class="badge badge-warning" title="Deep nesting may frustrate callers">@L["Ivr_Depth"] @menu.MaxDepth</span>
                    }
                </div>
                <div class="card-body">
                    <div class="stat-row">
                        <span class="text-muted">@L["Ivr_NameLabel"]</span> @menu.Name
                    </div>
                    @if (menu.Greeting is not null)
                    {
                        <div class="stat-row">
                            <span class="text-muted">@L["Ivr_GreetingLabel"]</span> @menu.Greeting
                        </div>
                    }
                    <div class="stat-row">
                        <span class="text-muted">@L["Ivr_OptionsLabel"]</span> @menu.ItemCount
                        @if (menu.SubMenuCount > 0)
                        {
                            <span class="text-muted ms-2">@L["Ivr_SubMenusLabel"]</span> @menu.SubMenuCount
                        }
                    </div>
                </div>
                <div class="card-footer">
                    <button class="btn btn-sm btn-danger" @onclick:stopPropagation="true"
                            @onclick="() => DeleteMenu(menu)">@L["Btn_Delete"]</button>
                </div>
            </div>
        }
    </div>
}

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@code {
    private List<IvrMenuViewModel> _menus = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is not null)
            _menus = await IvrSvc.GetRootMenusAsync(serverId);
        _loading = false;
    }

    private void NewMenu() => Nav.NavigateTo("/ivr-menus/edit/new");
    private void EditMenu(int id) => Nav.NavigateTo($"/ivr-menus/edit/{id}");

    private async Task DeleteMenu(IvrMenuViewModel menu)
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;

        var (success, error) = await IvrSvc.DeleteMenuAsync(serverId, menu.Id);
        if (success)
            _menus.Remove(menu);
        else
            _error = error;
    }
}
