@page "/trunks"
@using PbxAdmin.Services
@using PbxAdmin.Models
@inject ISelectedServerService ServerSvc
@inject ITrunkService TrunkSvc
@inject IConfigProviderResolver ConfigResolver
@inject IConfigOperationState ConfigOp
@inject IStringLocalizer<SharedStrings> L
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>@L["Trunk_Title"]</PageTitle>

<h2>@L["Trunk_Heading"]</h2>

<HelpPanel SectionKey="Trunks_Overview">@L["Trunk_Heading"]</HelpPanel>

@{
    var activeServer = ServerSvc.SelectedServerId;
    if (activeServer is not null)
    {
        var mode = ConfigResolver.GetConfigMode(activeServer);
        var modeBadge = mode == ConfigMode.Realtime ? "badge-realtime" : "badge-file";
        <p class="text-muted" style="margin-top: 0.25rem;">@L["Ext_ConfigBackend"] <span class="badge @modeBadge">@mode</span></p>
    }
}

<div class="kpi-grid kpi-grid-sm">
    <div class="kpi-card kpi-green">
        <div class="kpi-value">@_trunks.Count(t => t.Status == TrunkStatus.Registered)</div>
        <div class="kpi-label">@L["Ext_Registered"]</div>
    </div>
    <div class="kpi-card kpi-red">
        <div class="kpi-value">@_trunks.Count(t => t.Status is TrunkStatus.Unreachable or TrunkStatus.Rejected)</div>
        <div class="kpi-label">@L["Lbl_Unreachable"]</div>
    </div>
    <div class="kpi-card kpi-blue">
        <div class="kpi-value">@_trunks.Sum(t => t.ActiveCalls)</div>
        <div class="kpi-label">@L["Trunk_TotalCalls"]</div>
    </div>
    <div class="kpi-card kpi-gray">
        <div class="kpi-value">@_trunks.Count</div>
        <div class="kpi-label">@L["Trunk_TotalTrunks"]</div>
    </div>
</div>

<div class="chip-bar">
    <button class="chip @(_statusFilter is null ? "chip-active" : "")" @onclick="() => _statusFilter = null">@L["Lbl_All"]</button>
    <button class="chip @(_statusFilter == TrunkStatus.Registered ? "chip-active" : "")" @onclick="() => _statusFilter = TrunkStatus.Registered">@L["Ext_Registered"]</button>
    <button class="chip @(_statusFilter == TrunkStatus.Unreachable ? "chip-active" : "")" @onclick="() => _statusFilter = TrunkStatus.Unreachable">@L["Lbl_Unreachable"]</button>
    <button class="chip @(_statusFilter == TrunkStatus.Unknown ? "chip-active" : "")" @onclick="() => _statusFilter = TrunkStatus.Unknown">@L["Trunk_Unknown"]</button>
</div>

<div style="margin-bottom: 1rem;">
    <button class="btn btn-blue" @onclick="NavigateNew">@L["Trunk_NewTrunk"]</button>
</div>

<div class="card-grid">
    @foreach (var trunk in FilteredTrunks)
    {
        var statusClass = GetStatusClass(trunk.Status);
        var techBadge = GetTechBadge(trunk.Technology);
        <div class="trunk-card @statusClass">
            <div class="trunk-card-header">
                <span class="status-dot @GetDotClass(trunk.Status)"></span>
                <strong>@trunk.Name</strong>
                <span class="badge @techBadge">@trunk.Technology</span>
                <span class="badge badge-muted">@trunk.Status</span>
            </div>
            <div class="trunk-card-body">
                <div>@L["Trunk_Host"] @trunk.Host:@trunk.Port</div>
                @if (!string.IsNullOrEmpty(trunk.Codecs))
                {
                    <div>@L["Trunk_Codecs"] @trunk.Codecs</div>
                }
                @if (trunk.MaxChannels > 0)
                {
                    <div>@L["Trunk_CallCount"] @trunk.ActiveCalls / @trunk.MaxChannels</div>
                }
            </div>
            <div class="trunk-card-actions">
                <button class="btn btn-sm btn-blue" @onclick="() => NavigateDetail(trunk)">@L["Ext_Detail"]</button>
                <button class="btn btn-sm btn-yellow" @onclick="() => NavigateEdit(trunk)">@L["Btn_Edit"]</button>
                <button class="btn btn-sm btn-red" @onclick="() => ConfirmDelete(trunk)">@L["Btn_Delete"]</button>
            </div>
        </div>
    }
</div>

@if (_showDeleteConfirm)
{
    <div class="confirm-overlay" @onclick="CancelDelete">
        <div class="confirm-dialog" @onclick:stopPropagation="true">
            <h4>@L["Trunk_DeleteTitle"]</h4>
            <p>@L["Trunk_DeleteConfirm", _deletingTrunk?.Name ?? ""] @L["Ext_CannotUndo"]</p>
            <div class="confirm-dialog-actions">
                <button class="btn btn-sm" @onclick="CancelDelete">@L["Btn_Cancel"]</button>
                <button class="btn btn-sm btn-red" @onclick="ExecuteDelete">@L["Btn_Delete"]</button>
            </div>
        </div>
    </div>
}

@if (_actionResult is not null)
{
    <p class="action-result">@_actionResult</p>
}

@code {
    private Timer? _timer;
    private TrunkStatus? _statusFilter;
    private List<TrunkViewModel> _trunks = [];
    private bool _showDeleteConfirm;
    private TrunkViewModel? _deletingTrunk;
    private string? _actionResult;

    private IEnumerable<TrunkViewModel> FilteredTrunks =>
        _statusFilter.HasValue ? _trunks.Where(t => t.Status == _statusFilter.Value) : _trunks;

    protected override void OnInitialized()
    {
        _timer = new Timer(async _ =>
        {
            await LoadTrunks();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(5));
    }

    private async Task LoadTrunks()
    {
        try
        {
            var serverId = ServerSvc.SelectedServerId;
            if (serverId is null) return;
            _trunks = await TrunkSvc.GetTrunksAsync(serverId);
        }
        catch
        {
            // Silently handle errors during polling
        }
    }

    private void NavigateNew() =>
        Nav.NavigateTo($"/trunks/new?server={ServerSvc.SelectedServerId}");

    private void NavigateDetail(TrunkViewModel trunk) =>
        Nav.NavigateTo($"/trunks/{ServerSvc.SelectedServerId}/{trunk.Name}?tech={trunk.Technology}");

    private void NavigateEdit(TrunkViewModel trunk) =>
        Nav.NavigateTo($"/trunks/edit/{ServerSvc.SelectedServerId}/{trunk.Name}?tech={trunk.Technology}");

    private void ConfirmDelete(TrunkViewModel trunk)
    {
        _deletingTrunk = trunk;
        _showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        _showDeleteConfirm = false;
        _deletingTrunk = null;
    }

    private async Task ExecuteDelete()
    {
        if (_deletingTrunk is null) return;

        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;

        using var _ = ConfigOp.Begin("Deleting Trunk", serverId, _deletingTrunk.Name);
        var success = await TrunkSvc.DeleteTrunkAsync(serverId, _deletingTrunk.Name, _deletingTrunk.Technology);
        _actionResult = success
            ? $"Trunk '{_deletingTrunk.Name}' deleted successfully."
            : $"Failed to delete trunk '{_deletingTrunk.Name}'.";

        _showDeleteConfirm = false;
        _deletingTrunk = null;

        await LoadTrunks();
    }

    private static string GetStatusClass(TrunkStatus status) => status switch
    {
        TrunkStatus.Registered => "trunk-registered",
        TrunkStatus.Unregistered => "trunk-unregistered",
        TrunkStatus.Unreachable => "trunk-unreachable",
        TrunkStatus.Rejected => "trunk-rejected",
        _ => "trunk-unknown"
    };

    private static string GetDotClass(TrunkStatus status) => status switch
    {
        TrunkStatus.Registered => "dot-green",
        TrunkStatus.Unreachable or TrunkStatus.Rejected => "dot-red",
        TrunkStatus.Unregistered => "dot-yellow",
        _ => "dot-gray"
    };

    private static string GetTechBadge(TrunkTechnology tech) => tech switch
    {
        TrunkTechnology.PjSip => "badge-pjsip",
        TrunkTechnology.Sip => "badge-sip",
        TrunkTechnology.Iax2 => "badge-iax",
        _ => "badge-muted"
    };

    public void Dispose() => _timer?.Dispose();
}
