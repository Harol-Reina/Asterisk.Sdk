@page "/conferences/config/new"
@page "/conferences/config/{Id:int}"
@using PbxAdmin.Models
@using PbxAdmin.Services
@inject ConferenceConfigService ConfConfigSvc
@inject MohService MohSvc
@inject SelectedServerService ServerSvc
@inject NavigationManager Nav

<PageTitle>@(_isNew ? "New Conference Profile" : $"Edit {_config.Name}") — Asterisk PBX Admin</PageTitle>

<div class="page-header-row">
    <button class="btn btn-sm btn-muted" @onclick="GoBack">&#8592; Back</button>
    <h2>@(_isNew ? "New Conference Profile" : $"Edit: {_config.Name}")</h2>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

<div class="form-section">
    <h3>Bridge Settings</h3>

    <div class="form-group">
        <label>Name</label>
        <input type="text" @bind="_config.Name" class="form-control"
               placeholder="alphanumeric, hyphens, underscores" />
    </div>

    <div class="form-group">
        <label>Number (Extension)</label>
        <input type="text" @bind="_config.Number" class="form-control"
               placeholder="e.g. 6000" />
        <small class="text-muted">Dial-in extension for this conference room</small>
    </div>

    <div class="form-group">
        <label>Max Members</label>
        <input type="number" @bind="_config.MaxMembers" class="form-control" min="0" />
        <small class="text-muted">0 = unlimited</small>
    </div>
</div>

<div class="form-section">
    <h3>Security</h3>

    <div class="form-group">
        <label>User PIN</label>
        <input type="text" @bind="_config.Pin" class="form-control"
               placeholder="Digits only (leave empty for no PIN)" />
    </div>

    <div class="form-group">
        <label>Admin PIN</label>
        <input type="text" @bind="_config.AdminPin" class="form-control"
               placeholder="Digits only (leave empty for no admin PIN)" />
    </div>
</div>

<div class="form-section">
    <h3>Options</h3>

    <div class="form-group">
        <label>
            <input type="checkbox" @bind="_config.Record" />
            Auto-record conference
        </label>
    </div>

    <div class="form-group">
        <label>Music on Hold Class</label>
        <select @bind="_config.MusicOnHold" class="form-control">
            <option value="default">default</option>
            @foreach (var cls in _mohClasses)
            {
                <option value="@cls.Name">@cls.Name</option>
            }
        </select>
    </div>
</div>

<div class="form-actions">
    <button class="btn btn-muted" @onclick="GoBack">Cancel</button>
    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
        @(_saving ? "Saving..." : "Save")
    </button>
</div>

@code {
    [Parameter] public int Id { get; set; }

    private ConferenceConfig _config = new() { MusicOnHold = "default" };
    private List<MohClass> _mohClasses = [];
    private bool _isNew => Id == 0;
    private bool _saving;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;

        // Load MOH classes for dropdown
        try { _mohClasses = await MohSvc.GetClassesAsync(serverId); }
        catch { /* MOH list is optional */ }

        if (!_isNew)
        {
            var existing = await ConfConfigSvc.GetConfigAsync(Id);
            if (existing is not null)
                _config = existing;
        }
    }

    private async Task Save()
    {
        _saving = true;
        _error = null;

        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) { _error = "No server selected"; _saving = false; return; }

        var (success, error) = _isNew
            ? await ConfConfigSvc.CreateConfigAsync(serverId, _config)
            : await ConfConfigSvc.UpdateConfigAsync(serverId, _config);

        _saving = false;

        if (success)
            Nav.NavigateTo("/conferences");
        else
            _error = error;
    }

    private void GoBack() => Nav.NavigateTo("/conferences");
}
