@page "/trunks/new"
@page "/trunks/edit/{ServerId}/{TrunkName}"
@using PbxAdmin.Services
@using PbxAdmin.Models
@inject AsteriskMonitorService Monitor
@inject TrunkService TrunkSvc
@inject IStringLocalizer<SharedStrings> L
@inject ConfigOperationState ConfigOp
@inject NavigationManager Nav

<PageTitle>@(IsNew ? L["TrunkEdit_NewTitle"] : L["TrunkEdit_EditTitle", TrunkName ?? ""]) — Asterisk PBX Admin</PageTitle>

<a href="/trunks" class="back-link">@L["TrunkEdit_BackToList"]</a>
<h2>@(IsNew ? L["TrunkEdit_New"] : $"{L["TrunkEdit_Edit"]}: {TrunkName}")</h2>

@if (_loading)
{
    <p class="text-muted">@L["Lbl_Loading"]</p>
}
else
{
    <!-- Technology -->
    <div class="form-section">
        <h3>@L["ExtEdit_Technology"]</h3>
        <div class="radio-group">
            <label class="radio-option">
                <input type="radio" name="tech" value="@TrunkTechnology.PjSip" checked="@(_config.Technology == TrunkTechnology.PjSip)"
                       @onchange="() => _config.Technology = TrunkTechnology.PjSip" />
                PJSIP
            </label>
            <label class="radio-option">
                <input type="radio" name="tech" value="@TrunkTechnology.Sip" checked="@(_config.Technology == TrunkTechnology.Sip)"
                       @onchange="() => _config.Technology = TrunkTechnology.Sip" />
                SIP
            </label>
            <label class="radio-option">
                <input type="radio" name="tech" value="@TrunkTechnology.Iax2" checked="@(_config.Technology == TrunkTechnology.Iax2)"
                       @onchange="() => _config.Technology = TrunkTechnology.Iax2" />
                IAX2
            </label>
        </div>
    </div>

    <!-- Connection -->
    <div class="form-section">
        <h3>@L["TrunkEdit_Connection"]</h3>
        <div class="form-grid">
            <div class="form-field">
                <label class="form-label">@L["Lbl_Name"]</label>
                <input class="input" @bind="_config.Name" placeholder="my-trunk" disabled="@(!IsNew)" />
            </div>
            <div class="form-field">
                <label class="form-label">Host</label>
                <input class="input" @bind="_config.Host" placeholder="sip.provider.com" />
            </div>
            <div class="form-field">
                <label class="form-label">@L["TrunkEdit_Port"]</label>
                <input class="input" type="number" @bind="_config.Port" />
            </div>
            @if (_config.Technology != TrunkTechnology.Iax2)
            {
                <div class="form-field">
                    <label class="form-label">@L["ExtEdit_Transport"]</label>
                    <select @bind="_config.Transport">
                        <option value="udp">UDP</option>
                        <option value="tcp">TCP</option>
                        <option value="tls">TLS</option>
                        <option value="ws">WebSocket</option>
                        <option value="wss">WSS</option>
                    </select>
                </div>
            }
            <div class="form-field">
                <label class="form-label">@L["Lbl_Context"]</label>
                <input class="input" @bind="_config.Context" placeholder="from-trunk" />
            </div>
            <div class="form-field">
                <label class="form-label">@L["TrunkEdit_MaxChannels"]</label>
                <input class="input" type="number" @bind="_config.MaxChannels" />
            </div>
        </div>
    </div>

    <!-- Authentication -->
    <div class="form-section">
        <h3>@L["ExtEdit_Auth"]</h3>
        <div class="form-grid">
            <div class="form-field">
                <label class="form-label">@L["TrunkEdit_Username"]</label>
                <input class="input" @bind="_config.Username" placeholder="username" />
            </div>
            <div class="form-field">
                <label class="form-label">@L["TrunkEdit_Secret"]</label>
                <input class="input" type="password" @bind="_config.Secret" placeholder="password" />
            </div>
            @if (_config.Technology == TrunkTechnology.PjSip)
            {
                <div class="form-field">
                    <label class="form-label">@L["TrunkEdit_AuthType"]</label>
                    <select @bind="_config.AuthType">
                        <option value="userpass">User/Pass</option>
                        <option value="md5">MD5</option>
                    </select>
                </div>
            }
            <div class="form-field">
                <label class="form-label">@L["TrunkEdit_Registration"]</label>
                <label class="codec-check">
                    <input type="checkbox" @bind="_config.RegistrationEnabled" />
                    @L["TrunkEdit_EnableReg"]
                </label>
            </div>
        </div>
    </div>

    <!-- Media / Codecs -->
    <div class="form-section">
        <h3>@L["ExtEdit_Codecs"]</h3>
        <div class="form-field" style="margin-bottom: 0.75rem;">
            <label class="form-label">@L["ExtEdit_Codecs"]</label>
            <div class="codec-grid">
                @foreach (var codec in _availableCodecs)
                {
                    <label class="codec-check">
                        <input type="checkbox" checked="@IsCodecEnabled(codec)"
                               @onchange="e => ToggleCodec(codec, (bool)(e.Value ?? false))" />
                        @codec
                    </label>
                }
            </div>
        </div>
        @if (_config.Technology != TrunkTechnology.Iax2)
        {
            <div class="form-grid">
                <div class="form-field">
                    <label class="form-label">@L["ExtEdit_DtmfMode"]</label>
                    <select @bind="_config.DtmfMode">
                        <option value="rfc4733">RFC 4733</option>
                        <option value="rfc2833">RFC 2833</option>
                        <option value="inband">Inband</option>
                        <option value="info">SIP INFO</option>
                        <option value="auto">Auto</option>
                    </select>
                </div>
            </div>
        }
    </div>

    <!-- Advanced -->
    @if (_config.Technology != TrunkTechnology.Iax2)
    {
        <div class="form-section">
            <h3>@L["TrunkEdit_Advanced"]</h3>
            <div class="form-grid">
                @if (_config.Technology == TrunkTechnology.PjSip)
                {
                    <div class="form-field">
                        <label class="form-label">@L["TrunkEdit_QualifyFreq"]</label>
                        <input class="input" type="number" @bind="_config.QualifyFrequency" />
                    </div>
                }
                <div class="form-field">
                    <label class="form-label">@L["ExtEdit_NatOptions"]</label>
                    <label class="codec-check">
                        <input type="checkbox" @bind="_config.ForceRport" />
                        @L["ExtEdit_ForceRport"]
                    </label>
                    <label class="codec-check">
                        <input type="checkbox" @bind="_config.Comedia" />
                        @L["TrunkEdit_Comedia"]
                    </label>
                </div>
                <div class="form-field">
                    <label class="form-label">@L["TrunkEdit_CallerIdNum"]</label>
                    <input class="input" @bind="_config.CallerIdNum" placeholder="5551234567" />
                </div>
                <div class="form-field">
                    <label class="form-label">@L["TrunkEdit_CallerIdName"]</label>
                    <input class="input" @bind="_config.CallerIdName" placeholder="My Company" />
                </div>
            </div>
        </div>
    }

    <!-- Notes -->
    <div class="form-section">
        <h3>@L["TrunkEdit_Notes"]</h3>
        <div class="form-field">
            <textarea class="input" @bind="_config.Notes" rows="3" placeholder="Optional notes about this trunk..." style="width:100%;resize:vertical;"></textarea>
        </div>
    </div>

    <div class="form-actions">
        <button class="btn btn-green" @onclick="Save" disabled="@_saving">@(_saving ? L["Btn_Saving"] : L["Btn_Save"])</button>
        <button class="btn" @onclick="NavigateBack">@L["Btn_Cancel"]</button>
    </div>

    @if (_result is not null)
    {
        <p class="action-result">@_result</p>
    }
}

@code {
    [Parameter] public string? ServerId { get; set; }
    [Parameter] public string? TrunkName { get; set; }

    [SupplyParameterFromQuery] public string? Server { get; set; }
    [SupplyParameterFromQuery] public string? Tech { get; set; }

    private bool IsNew => TrunkName is null;
    private TrunkConfig _config = new();
    private bool _loading = true;
    private bool _saving;
    private string? _result;

    private static readonly string[] _availableCodecs = ["ulaw", "alaw", "g729", "opus", "gsm", "g722"];

    protected override async Task OnInitializedAsync()
    {
        var serverId = ServerId ?? Server ?? Monitor.Servers.Select(s => s.Key).FirstOrDefault();

        if (!IsNew && serverId is not null)
        {
            var technology = Enum.TryParse<TrunkTechnology>(Tech, true, out var t) ? t : TrunkTechnology.PjSip;
            var detail = await TrunkSvc.GetTrunkDetailAsync(serverId, TrunkName!, technology);
            if (detail is not null)
            {
                _config = detail.Config;
            }
        }
        else
        {
            _config.Port = 5060;
        }

        _loading = false;
    }

    private bool IsCodecEnabled(string codec)
    {
        var codecs = _config.Codecs.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return codecs.Contains(codec, StringComparer.OrdinalIgnoreCase);
    }

    private void ToggleCodec(string codec, bool enabled)
    {
        var codecs = _config.Codecs
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();

        if (enabled && !codecs.Contains(codec, StringComparer.OrdinalIgnoreCase))
            codecs.Add(codec);
        else if (!enabled)
            codecs.RemoveAll(c => string.Equals(c, codec, StringComparison.OrdinalIgnoreCase));

        _config.Codecs = string.Join(",", codecs);
    }

    private async Task Save()
    {
        var serverId = ServerId ?? Server ?? Monitor.Servers.Select(s => s.Key).FirstOrDefault();
        if (serverId is null)
        {
            _result = "No server selected.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_config.Name))
        {
            _result = "Trunk name is required.";
            return;
        }

        _saving = true;
        _result = null;

        try
        {
            var opName = IsNew ? "Creating Trunk" : "Updating Trunk";
            using var _ = ConfigOp.Begin(opName, serverId, _config.Name);
            bool success;
            if (IsNew)
            {
                success = await TrunkSvc.CreateTrunkAsync(serverId, _config);
            }
            else
            {
                success = await TrunkSvc.UpdateTrunkAsync(serverId, _config);
            }

            if (success)
            {
                Nav.NavigateTo("/trunks");
            }
            else
            {
                _result = "Failed to save trunk. Check server logs for details.";
            }
        }
        catch (Exception ex)
        {
            _result = $"Error: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private void NavigateBack() => Nav.NavigateTo("/trunks");
}
