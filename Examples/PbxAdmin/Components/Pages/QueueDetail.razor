@page "/queue/{ServerId}/{QueueName}"
@using PbxAdmin.Services
@using Asterisk.Sdk.Live
@using Asterisk.Sdk.Live.Queues
@using PbxAdmin.Models
@using Asterisk.Sdk.Ami.Actions
@inject AsteriskMonitorService Monitor
@inject ICallSessionManager Sessions
@inject QueueService QueueSvc
@inject ConfigOperationState ConfigOp
@inject NavigationManager Nav
@inject QueueConfigService QueueCfgSvc
@inject IStringLocalizer<SharedStrings> L
@implements IDisposable

<PageTitle>@QueueName — Asterisk PBX Admin</PageTitle>

<div class="page-header-row">
    <h2>
        <a href="/queues" class="back-link">Queues</a> / @QueueName
        <span class="badge badge-muted">@ServerId</span>
    </h2>
    <button class="btn btn-sm btn-red" @onclick="ConfirmDelete" disabled="@_deleteInProgress">@L["QDetail_DeleteQueue"]</button>
</div>

@if (_showDeleteConfirm)
{
    <div class="confirm-bar confirm-bar-danger">
        <span>@L["QDetail_DeleteConfirm"] <strong>@QueueName</strong></span>
        <button class="btn btn-sm btn-red" @onclick="DeleteQueue" disabled="@_deleteInProgress">
            @(_deleteInProgress ? L["QDetail_Deleting"] : L["QDetail_ConfirmDelete"])
        </button>
        <button class="btn btn-sm btn-muted" @onclick="() => _showDeleteConfirm = false" disabled="@_deleteInProgress">@L["Btn_Cancel"]</button>
    </div>
}

@if (_queue is null)
{
    <p>@L["QDetail_NotFound"]</p>
}
else
{
    <div class="stats-bar">
        <div class="stat-item"><strong>@_queue.Max</strong> @L["QDetail_Max"]</div>
        <div class="stat-item"><strong>@_queue.Strategy</strong> @L["QDetail_Strategy"]</div>
        <div class="stat-item"><strong>@_queue.Calls</strong> @L["QDetail_Calls"]</div>
        <div class="stat-item"><strong>@FormatSeconds(_queue.HoldTime)</strong> @L["QDetail_Hold"]</div>
        <div class="stat-item"><strong>@FormatSeconds(_queue.TalkTime)</strong> @L["QDetail_Talk"]</div>
        <div class="stat-item"><strong>@_queue.Completed</strong> @L["Queues_Done"]</div>
        <div class="stat-item"><strong>@_queue.Abandoned</strong> @L["Queues_Dropped"]</div>
    </div>

    <div class="form-section">
        <div class="page-header-row">
            <h3>@L["QDetail_Configuration"]</h3>
            @if (_queueConfig is not null)
            {
                <a href="/queue-config/@ServerId/@_queueConfig.Id" class="btn btn-sm btn-blue">@L["QDetail_EditConfig"]</a>
            }
            else
            {
                <a href="/queue-config/@ServerId/new?name=@QueueName" class="btn btn-sm btn-green">@L["QDetail_Configure"]</a>
            }
        </div>
        @if (_queueConfig is not null)
        {
            <div class="stats-bar">
                <div class="stat-item"><strong>@_queueConfig.Strategy</strong> @L["QDetail_Strategy"]</div>
                <div class="stat-item"><strong>@_queueConfig.Timeout</strong>s Timeout</div>
                <div class="stat-item"><strong>@_queueConfig.Retry</strong>s Retry</div>
                <div class="stat-item"><strong>@(_queueConfig.MaxLen == 0 ? "∞" : _queueConfig.MaxLen)</strong> @L["QDetail_Max"]</div>
                <div class="stat-item"><strong>@_queueConfig.WrapUpTime</strong>s Wrap-up</div>
                <div class="stat-item"><strong>@_queueConfig.ServiceLevel</strong>s SLA</div>
                <div class="stat-item"><strong>@_queueConfig.MusicOnHold</strong> MOH</div>
                <div class="stat-item"><strong>@(_queueConfig.Enabled ? L["Lbl_Yes"] : L["Lbl_No"])</strong> @L["Lbl_Enabled"]</div>
            </div>
        }
        else
        {
            <p class="text-muted">@L["QDetail_NotConfigured"]</p>
        }
    </div>

    <h3>@L["QDetail_AgentsSection"] (@_queue.MemberCount)</h3>
    <div class="card-grid">
        @foreach (var member in _queue.Members.Values)
        {
            var (dotClass, icon) = GetMemberStyle(member);
            <div class="agent-card @dotClass">
                <div class="agent-card-header">
                    <span class="status-dot @dotClass"></span>
                    <strong>@(member.MemberName ?? member.Interface)</strong>
                    <span class="agent-icon">@icon</span>
                </div>
                <div class="agent-card-body">
                    <div>@member.Interface</div>
                    <div>@L["QDetail_AgentStatus"]: @member.Status</div>
                    <div>@L["QDetail_AgentCalls"]: @member.CallsTaken | @L["QDetail_AgentPenalty"]: @member.Penalty</div>
                    @if (member.Paused)
                    {
                        <div class="badge badge-yellow">Paused @(member.PausedReason is not null ? $"— {member.PausedReason}" : "")</div>
                    }
                    @{
                        var memberCall = Sessions.FindByChannel(member.Interface);
                    }
                    @if (memberCall is not null)
                    {
                        <a href="/calls/@Uri.EscapeDataString(memberCall.SessionId)" class="badge badge-blue">Active Call</a>
                    }
                </div>
                <div class="agent-card-actions">
                    @if (member.Paused)
                    {
                        <button class="btn btn-sm btn-green" @onclick="() => TogglePause(member, false)">@L["QDetail_Unpause"]</button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-yellow" @onclick="() => TogglePause(member, true)">@L["QDetail_Pause"]</button>
                    }
                    <button class="btn btn-sm btn-red" @onclick="() => RemoveMember(member)">@L["Btn_Remove"]</button>
                </div>
            </div>
        }
    </div>

    <h3>@L["QDetail_CallersWaiting"] (@_queue.EntryCount)</h3>
    @if (_queue.EntryCount > 0)
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>@L["Col_Pos"]</th>
                    <th>@L["Col_CallerID"]</th>
                    <th>@L["Col_Channel"]</th>
                    <th>@L["Col_WaitTime"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in _queue.Entries.Values.OrderBy(e => e.Position))
                {
                    var callerCall = Sessions.FindByChannel(entry.Channel);
                    <tr>
                        <td>@entry.Position</td>
                        <td>@entry.CallerId</td>
                        <td>@entry.Channel</td>
                        <td class="caller-timer">@FormatDuration(DateTimeOffset.UtcNow - entry.JoinedAt)</td>
                        <td>
                            @if (callerCall is not null)
                            {
                                <a href="/calls/@Uri.EscapeDataString(callerCall.SessionId)" class="badge badge-blue">@L["QDetail_ViewCall"]</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">@L["QDetail_NoCallers"]</p>
    }

    <h3>@L["QDetail_AddMember"]</h3>
    <div class="inline-form">
        <input @bind="_addInterface" placeholder="PJSIP/3000" class="input" />
        <input @bind="_addMemberName" placeholder="Agent Name" class="input" />
        <input @bind="_addPenalty" type="number" placeholder="Penalty" class="input input-sm" />
        <button class="btn btn-blue" @onclick="AddMember">@L["Btn_Add"]</button>
    </div>
    @if (_actionMessage is not null)
    {
        <p class="action-result">@_actionMessage</p>
    }
}

@code {
    [Parameter] public string ServerId { get; set; } = "";
    [Parameter] public string QueueName { get; set; } = "";

    private Timer? _timer;
    private AsteriskQueue? _queue;
    private QueueConfigDto? _queueConfig;
    private string _addInterface = "";
    private string _addMemberName = "";
    private int _addPenalty;
    private string? _actionMessage;
    private bool _showDeleteConfirm;
    private bool _deleteInProgress;

    protected override async Task OnInitializedAsync()
    {
        RefreshQueue();
        var queues = await QueueCfgSvc.GetQueuesAsync(ServerId);
        _queueConfig = queues.FirstOrDefault(q =>
            string.Equals(q.Name, QueueName, StringComparison.OrdinalIgnoreCase));
        _timer = new Timer(_ => { RefreshQueue(); InvokeAsync(StateHasChanged); },
            null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void RefreshQueue()
    {
        var entry = Monitor.GetServer(ServerId);
        _queue = entry?.Server.Queues.GetByName(QueueName);
    }

    private async Task TogglePause(AsteriskQueueMember member, bool pause)
    {
        var entry = Monitor.GetServer(ServerId);
        if (entry is null) return;

        var iface = member.Interface;
        if (string.IsNullOrEmpty(QueueName) || string.IsNullOrEmpty(iface))
        {
            _actionMessage = $"Pause failed: missing Queue=\"{QueueName}\" or Interface=\"{iface}\"";
            return;
        }

        using var _ = ConfigOp.Begin(pause ? "Pausing Member" : "Unpausing Member", ServerId, $"{QueueName}/{iface}");
        var response = await entry.ConfigConnection.SendActionAsync(new QueuePauseAction
        {
            Queue = QueueName,
            Interface = iface,
            Paused = pause
        });
        _actionMessage = $"Pause {(pause ? "on" : "off")}: {response.Response} — {response.Message}";
    }

    private async Task RemoveMember(AsteriskQueueMember member)
    {
        var entry = Monitor.GetServer(ServerId);
        if (entry is null) return;

        var iface = member.Interface;
        if (string.IsNullOrEmpty(QueueName) || string.IsNullOrEmpty(iface))
        {
            _actionMessage = $"Remove failed: missing Queue=\"{QueueName}\" or Interface=\"{iface}\"";
            return;
        }

        using var _ = ConfigOp.Begin("Removing Member", ServerId, $"{QueueName}/{iface}");
        var response = await entry.ConfigConnection.SendActionAsync(new QueueRemoveAction
        {
            Queue = QueueName,
            Interface = iface
        });
        _actionMessage = $"Remove: {response.Response} — {response.Message}";
    }

    private void ConfirmDelete() => _showDeleteConfirm = true;

    private async Task DeleteQueue()
    {
        if (_deleteInProgress) return;
        _deleteInProgress = true;
        _actionMessage = "Deleting queue...";

        try
        {
            using var _ = ConfigOp.Begin("Deleting Queue", ServerId, QueueName);
            var success = await QueueSvc.DeleteQueueAsync(ServerId, QueueName);
            if (success)
            {
                Nav.NavigateTo("/queues");
            }
            else
            {
                _actionMessage = "Failed to delete queue.";
                _showDeleteConfirm = false;
            }
        }
        finally
        {
            _deleteInProgress = false;
        }
    }

    private async Task AddMember()
    {
        if (string.IsNullOrWhiteSpace(_addInterface)) return;

        var entry = Monitor.GetServer(ServerId);
        if (entry is null) return;

        using var _ = ConfigOp.Begin("Adding Member", ServerId, $"{QueueName}/{_addInterface}");
        var response = await entry.ConfigConnection.SendActionAsync(new QueueAddAction
        {
            Queue = QueueName,
            Interface = _addInterface,
            MemberName = string.IsNullOrWhiteSpace(_addMemberName) ? null : _addMemberName,
            Penalty = _addPenalty
        });
        _actionMessage = $"Add: {response.Response} — {response.Message}";
        _addInterface = "";
        _addMemberName = "";
        _addPenalty = 0;
    }

    private static (string dotClass, string icon) GetMemberStyle(AsteriskQueueMember member)
    {
        if (member.Paused) return ("status-paused", "\u23F8");
        return member.Status switch
        {
            QueueMemberState.DeviceNotInUse => ("status-available", "\u2713"),
            QueueMemberState.DeviceInUse => ("status-incall", "\uD83D\uDCDE"),
            QueueMemberState.DeviceBusy => ("status-busy", "\u26D4"),
            QueueMemberState.DeviceRinging or QueueMemberState.DeviceRingInUse => ("status-ringing", "\uD83D\uDD14"),
            QueueMemberState.DeviceOnHold => ("status-hold", "\u23F3"),
            QueueMemberState.DeviceUnavailable => ("status-offline", "\u2715"),
            _ => ("status-unknown", "?")
        };
    }

    private static string FormatSeconds(int seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return ts.TotalMinutes >= 1 ? $"{(int)ts.TotalMinutes}m{ts.Seconds:D2}s" : $"{ts.Seconds}s";
    }

    private static string FormatDuration(TimeSpan ts) =>
        ts.TotalMinutes >= 1 ? $"{(int)ts.TotalMinutes}:{ts.Seconds:D2}" : $"0:{ts.Seconds:D2}";

    public void Dispose() => _timer?.Dispose();
}
