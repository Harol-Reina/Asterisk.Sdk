@page "/queue-config/{ServerId}/{IdOrNew}"
@using PbxAdmin.Models
@using PbxAdmin.Services
@using Microsoft.AspNetCore.WebUtilities
@inject QueueConfigService QueueCfgSvc
@inject NavigationManager Nav
@inject ConfigOperationState ConfigOp
@inject IStringLocalizer<SharedStrings> L

<PageTitle>@(_isNew ? L["QCfg_NewTitle"] : $"{L["QCfg_EditTitle"]} {_config.Name}") — Asterisk PBX Admin</PageTitle>

<div class="page-header-row">
    <h2>
        <a href="/queues" class="back-link">Queues</a> / @(_isNew ? L["QCfg_NewTitle"] : _config.Name)
        <span class="badge badge-muted">@ServerId</span>
    </h2>
</div>

@if (_result is not null)
{
    <div class="alert alert-danger">@_result</div>
}

<div class="form-section">
    <HelpPanel SectionKey="QCfg_Identity">@L["QCfg_Identity"]</HelpPanel>
    <div class="form-grid">
        <div class="form-field">
            <label class="form-label">@L["Lbl_Name"] <HelpIcon HelpKey="QueueName" /></label>
            <input class="input" @bind="_config.Name" readonly="@(!_isNew)" />
        </div>
        <div class="form-field">
            <label class="form-label">@L["Lbl_Enabled"]</label>
            <input type="checkbox" @bind="_config.Enabled" />
        </div>
        <div class="form-field full-width">
            <label class="form-label">@L["Lbl_Notes"]</label>
            <textarea class="input" @bind="_config.Notes" rows="2"></textarea>
        </div>
    </div>
</div>

<div class="form-section">
    <HelpPanel SectionKey="QCfg_StrategyTiming">@L["QCfg_StrategyTiming"]</HelpPanel>
    <div class="form-grid">
        <div class="form-field">
            <label class="form-label">@L["QCfg_Strategy"] <HelpIcon HelpKey="QueueStrategy" /></label>
            <select class="input" @bind="_config.Strategy">
                <option value="ringall">Ring All</option>
                <option value="roundrobin">Round Robin</option>
                <option value="leastrecent">Least Recent</option>
                <option value="fewestcalls">Fewest Calls</option>
                <option value="random">Random</option>
                <option value="rrmemory">Round Robin w/ Memory</option>
                <option value="linear">Linear</option>
                <option value="wrandom">Weighted Random</option>
            </select>
        </div>
        <div class="form-field">
            <label class="form-label">@L["QCfg_RingTimeout"] <HelpIcon HelpKey="QueueTimeout" /></label>
            <input type="number" class="input" @bind="_config.Timeout" min="1" />
        </div>
        <div class="form-field">
            <label class="form-label">@L["QCfg_Retry"]</label>
            <input type="number" class="input" @bind="_config.Retry" min="0" />
        </div>
        <div class="form-field">
            <label class="form-label">@L["QCfg_Weight"]</label>
            <input type="number" class="input" @bind="_config.Weight" min="0" />
        </div>
    </div>
</div>

<div class="form-section">
    <h3>@L["QCfg_Capacity"]</h3>
    <div class="form-grid">
        <div class="form-field">
            <label class="form-label">@L["QCfg_MaxCallers"] <HelpIcon HelpKey="QueueMaxCallers" /></label>
            <input type="number" class="input" @bind="_config.MaxLen" min="0" />
        </div>
        <div class="form-field">
            <label class="form-label">@L["QCfg_WrapupTime"]</label>
            <input type="number" class="input" @bind="_config.WrapUpTime" min="0" />
        </div>
        <div class="form-field">
            <label class="form-label">@L["QCfg_ServiceLevel"] <HelpIcon HelpKey="QueueServiceLevel" /></label>
            <input type="number" class="input" @bind="_config.ServiceLevel" min="0" />
        </div>
        <div class="form-field">
            <label class="form-label">@L["QCfg_RingInUse"]</label>
            <select class="input" @bind="_config.RingInUse">
                <option value="yes">@L["Lbl_Yes"]</option>
                <option value="no">@L["Lbl_No"]</option>
            </select>
        </div>
    </div>
</div>

<div class="form-section">
    <h3>@L["QCfg_MusicJoinLeave"]</h3>
    <div class="form-grid">
        <div class="form-field">
            <label class="form-label">@L["QCfg_MohClass"]</label>
            <input class="input" @bind="_config.MusicOnHold" />
        </div>
        <div class="form-field">
            <label class="form-label">@L["QCfg_JoinEmpty"]</label>
            <select class="input" @bind="_config.JoinEmpty">
                <option value="yes">@L["Lbl_Yes"]</option>
                <option value="no">@L["Lbl_No"]</option>
                <option value="strict">@L["QCfg_Strict"]</option>
                <option value="loose">@L["QCfg_Loose"]</option>
            </select>
        </div>
        <div class="form-field">
            <label class="form-label">@L["QCfg_LeaveEmpty"]</label>
            <select class="input" @bind="_config.LeaveWhenEmpty">
                <option value="yes">@L["Lbl_Yes"]</option>
                <option value="no">@L["Lbl_No"]</option>
                <option value="strict">@L["QCfg_Strict"]</option>
                <option value="loose">@L["QCfg_Loose"]</option>
            </select>
        </div>
    </div>
</div>

<div class="form-section">
    <h3>@L["QCfg_Announcements"]</h3>
    <div class="form-grid">
        <div class="form-field">
            <label class="form-label">@L["QCfg_AnnounceFreq"]</label>
            <input type="number" class="input" @bind="_config.AnnounceFrequency" min="0" />
        </div>
        <div class="form-field">
            <label class="form-label">@L["QCfg_AnnounceHold"]</label>
            <select class="input" @bind="_config.AnnounceHoldTime">
                <option value="yes">@L["Lbl_Yes"]</option>
                <option value="no">@L["Lbl_No"]</option>
                <option value="once">@L["QCfg_Once"]</option>
            </select>
        </div>
        <div class="form-field">
            <label class="form-label">@L["QCfg_AnnouncePosition"]</label>
            <select class="input" @bind="_config.AnnouncePosition">
                <option value="yes">@L["Lbl_Yes"]</option>
                <option value="no">@L["Lbl_No"]</option>
                <option value="once">@L["QCfg_Once"]</option>
            </select>
        </div>
        <div class="form-field">
            <label class="form-label">@L["QCfg_PeriodicFile"]</label>
            <input class="input" @bind="_config.PeriodicAnnounce" />
        </div>
        <div class="form-field">
            <label class="form-label">@L["QCfg_PeriodicFreq"]</label>
            <input type="number" class="input" @bind="_config.PeriodicAnnounceFrequency" min="0" />
        </div>
    </div>
</div>

<div class="form-section">
    <h3>@L["QCfg_CustomPrompts"]</h3>
    <div class="form-grid">
        <div class="form-field">
            <label class="form-label">@L["QCfg_YouAreNext"]</label>
            <input class="input" @bind="_config.QueueYouAreNext" />
        </div>
        <div class="form-field">
            <label class="form-label">@L["QCfg_ThereAre"]</label>
            <input class="input" @bind="_config.QueueThereAre" />
        </div>
        <div class="form-field">
            <label class="form-label">@L["QCfg_CallsWaiting"]</label>
            <input class="input" @bind="_config.QueueCallsWaiting" />
        </div>
    </div>
</div>

<div class="form-section">
    <HelpPanel SectionKey="QCfg_StaticMembers">@L["QCfg_StaticMembers"] (@_config.Members.Count)</HelpPanel>
    <div class="inline-form">
        <input class="input" @bind="_newMemberInterface" placeholder="PJSIP/2001" />
        <input class="input" @bind="_newMemberName" placeholder="Agent Name" />
        <input class="input" @bind="_newMemberStateInterface" placeholder="State Interface (optional)" />
        <input type="number" class="input input-sm" @bind="_newMemberPenalty" min="0" placeholder="Penalty" />
        <button class="btn btn-blue" @onclick="AddMember">@L["Btn_Add"]</button>
    </div>
    @if (_config.Members.Count > 0)
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>@L["Col_Interface"]</th>
                    <th>@L["Lbl_Name"]</th>
                    <th>@L["Col_StateInterface"]</th>
                    <th>@L["Col_Penalty"]</th>
                    <th>@L["Col_Paused"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var member in _config.Members)
                {
                    <tr>
                        <td>@member.Interface</td>
                        <td>@member.MemberName</td>
                        <td>@member.StateInterface</td>
                        <td>@member.Penalty</td>
                        <td>@(member.Paused == 1 ? L["Lbl_Yes"] : L["Lbl_No"])</td>
                        <td><button class="btn btn-sm btn-red" @onclick="() => RemoveMember(member)">@L["Btn_Remove"]</button></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<div class="form-actions">
    <button class="btn btn-green" @onclick="Save" disabled="@_saving">
        @(_saving ? L["Btn_Saving"] : L["Btn_Save"])
    </button>
    <button class="btn btn-muted" @onclick="Cancel">@L["Btn_Cancel"]</button>
    @if (!_isNew)
    {
        <button class="btn btn-red" @onclick="() => _showDeleteConfirm = true">@L["Btn_Delete"]</button>
    }
</div>

@if (_showDeleteConfirm)
{
    <div class="confirm-bar confirm-bar-danger">
        <span>@L["QCfg_DeleteQueue"] <strong>@_config.Name</strong>? @L["QCfg_DeleteWarn"]</span>
        <button class="btn btn-sm btn-red" @onclick="Delete" disabled="@_saving">@L["Btn_Confirm"]</button>
        <button class="btn btn-sm btn-muted" @onclick="() => _showDeleteConfirm = false">@L["Btn_Cancel"]</button>
    </div>
}

@code {
    [Parameter] public string ServerId { get; set; } = "";
    [Parameter] public string IdOrNew { get; set; } = "";

    private QueueConfigDto _config = new();
    private bool _isNew;
    private bool _saving;
    private bool _showDeleteConfirm;
    private string? _result;

    private string _newMemberInterface = "";
    private string? _newMemberName;
    private string? _newMemberStateInterface;
    private int _newMemberPenalty;

    protected override async Task OnInitializedAsync()
    {
        _isNew = string.Equals(IdOrNew, "new", StringComparison.OrdinalIgnoreCase);

        if (!_isNew && int.TryParse(IdOrNew, out var id))
        {
            var existing = await QueueCfgSvc.GetQueueAsync(id);
            if (existing is not null)
            {
                _config = existing;
                _config.Members = await QueueCfgSvc.GetMembersAsync(id);
            }
            else
            {
                Nav.NavigateTo("/queues");
                return;
            }
        }
        else if (_isNew)
        {
            _config.ServerId = ServerId;
            var uri = Nav.ToAbsoluteUri(Nav.Uri);
            if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("name", out var nameValues))
                _config.Name = nameValues.ToString();
        }
    }

    private void AddMember()
    {
        if (string.IsNullOrWhiteSpace(_newMemberInterface)) return;
        if (_config.Members.Any(m => string.Equals(m.Interface, _newMemberInterface, StringComparison.OrdinalIgnoreCase))) return;

        _config.Members.Add(new QueueMemberConfigDto
        {
            Interface = _newMemberInterface,
            MemberName = _newMemberName,
            StateInterface = _newMemberStateInterface,
            Penalty = _newMemberPenalty,
        });

        _newMemberInterface = "";
        _newMemberName = null;
        _newMemberStateInterface = null;
        _newMemberPenalty = 0;
    }

    private void RemoveMember(QueueMemberConfigDto member) => _config.Members.Remove(member);

    private async Task Save()
    {
        _saving = true;
        _result = null;

        try
        {
            _config.ServerId = ServerId;
            var opName = _isNew ? "Creating Queue Config" : "Updating Queue Config";
            using var _ = ConfigOp.Begin(opName, ServerId, _config.Name);

            var (success, error) = _isNew
                ? await QueueCfgSvc.CreateQueueAsync(_config)
                : await QueueCfgSvc.UpdateQueueAsync(_config);

            if (success)
                Nav.NavigateTo("/queues");
            else
                _result = error ?? "Failed to save queue configuration.";
        }
        catch (Exception ex)
        {
            _result = $"Error: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Delete()
    {
        _saving = true;
        try
        {
            using var _ = ConfigOp.Begin("Deleting Queue Config", ServerId, _config.Name);
            var (success, error) = await QueueCfgSvc.DeleteQueueAsync(ServerId, _config.Id);

            if (success)
                Nav.NavigateTo("/queues");
            else
                _result = error ?? "Failed to delete queue.";
        }
        catch (Exception ex)
        {
            _result = $"Error: {ex.Message}";
        }
        finally
        {
            _saving = false;
            _showDeleteConfirm = false;
        }
    }

    private void Cancel() => Nav.NavigateTo("/queues");
}
