@page "/ivr-menus"
@using DashboardExample.Models
@using DashboardExample.Services
@inject IvrMenuService IvrSvc
@inject SelectedServerService ServerSvc
@inject NavigationManager Nav

<PageTitle>IVR Menus — Asterisk Dashboard</PageTitle>

<div class="page-header-row">
    <h2>IVR Menus</h2>
    <button class="btn btn-primary" @onclick="NewMenu">+ New IVR</button>
</div>

@if (_loading)
{
    <p>Loading...</p>
}
else if (_menus.Count == 0)
{
    <p class="text-muted">No IVR menus configured. Click "New IVR" to create one.</p>
}
else
{
    <div class="card-grid">
        @foreach (var menu in _menus)
        {
            <div class="card clickable" @onclick="() => EditMenu(menu.Id)">
                <div class="card-header">
                    <strong>@menu.Label</strong>
                    @if (!menu.Enabled)
                    {
                        <span class="badge badge-muted">Disabled</span>
                    }
                    @if (menu.MaxDepth > 3)
                    {
                        <span class="badge badge-warning" title="Deep nesting may frustrate callers">Depth @menu.MaxDepth</span>
                    }
                </div>
                <div class="card-body">
                    <div class="stat-row">
                        <span class="text-muted">Name:</span> @menu.Name
                    </div>
                    @if (menu.Greeting is not null)
                    {
                        <div class="stat-row">
                            <span class="text-muted">Greeting:</span> @menu.Greeting
                        </div>
                    }
                    <div class="stat-row">
                        <span class="text-muted">Options:</span> @menu.ItemCount
                        @if (menu.SubMenuCount > 0)
                        {
                            <span class="text-muted ms-2">Sub-menus:</span> @menu.SubMenuCount
                        }
                    </div>
                </div>
                <div class="card-footer">
                    <button class="btn btn-sm btn-danger" @onclick:stopPropagation="true"
                            @onclick="() => DeleteMenu(menu)">Delete</button>
                </div>
            </div>
        }
    </div>
}

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@code {
    private List<IvrMenuViewModel> _menus = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is not null)
            _menus = await IvrSvc.GetRootMenusAsync(serverId);
        _loading = false;
    }

    private void NewMenu() => Nav.NavigateTo("/ivr-menus/edit/new");
    private void EditMenu(int id) => Nav.NavigateTo($"/ivr-menus/edit/{id}");

    private async Task DeleteMenu(IvrMenuViewModel menu)
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;

        var (success, error) = await IvrSvc.DeleteMenuAsync(serverId, menu.Id);
        if (success)
            _menus.Remove(menu);
        else
            _error = error;
    }
}
