@page "/campaign-metrics"
@using DashboardExample.Services
@inject CallFlowTracker CallTracker
@inject SelectedServerService ServerSvc
@implements IDisposable

<PageTitle>Campaign Metrics — Asterisk Dashboard</PageTitle>

<h2>Campaign Metrics</h2>

<div class="kpi-grid">
    <div class="kpi-card kpi-blue">
        <div class="kpi-value">@_originated</div>
        <div class="kpi-label">Originated</div>
    </div>
    <div class="kpi-card kpi-green">
        <div class="kpi-value">@_answered (@_answeredPct%)</div>
        <div class="kpi-label">Answered</div>
    </div>
    <div class="kpi-card kpi-red">
        <div class="kpi-value">@_unanswered (@_unansweredPct%)</div>
        <div class="kpi-label">Unanswered</div>
    </div>
    <div class="kpi-card kpi-purple">
        <div class="kpi-value">@_bridged (@_bridgedPct%)</div>
        <div class="kpi-label">Bridged to Agent</div>
    </div>
</div>

<div class="kpi-grid kpi-grid-sm">
    <div class="kpi-card kpi-orange">
        <div class="kpi-value">@_activeNow</div>
        <div class="kpi-label">Active Now</div>
    </div>
    <div class="kpi-card kpi-gray">
        <div class="kpi-value">@_completed</div>
        <div class="kpi-label">Completed</div>
    </div>
    <div class="kpi-card kpi-blue">
        <div class="kpi-value">@_avgDuration</div>
        <div class="kpi-label">Avg Duration</div>
    </div>
    <div class="kpi-card kpi-yellow">
        <div class="kpi-value">@_avgWait</div>
        <div class="kpi-label">Avg Wait</div>
    </div>
</div>

<label style="margin: 1rem 0; display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer;">
    <input type="checkbox" @bind="_showAdvanced" />
    Show Advanced Breakdown
</label>

@if (_showAdvanced)
{
    <h3>State Breakdown</h3>
    <table class="data-table">
        <thead>
            <tr>
                <th>State</th>
                <th>Count</th>
                <th>%</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in _stateBreakdown)
            {
                <tr>
                    <td>@row.State</td>
                    <td>@row.Count</td>
                    <td>@row.Pct%</td>
                </tr>
            }
        </tbody>
    </table>

    <h3>Top Queues</h3>
    <table class="data-table">
        <thead>
            <tr>
                <th>Queue</th>
                <th>Calls</th>
                <th>Answered</th>
                <th>Answer Rate</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in _topQueues)
            {
                <tr>
                    <td>@row.Queue</td>
                    <td>@row.Calls</td>
                    <td>@row.Answered</td>
                    <td>@row.AnswerRate%</td>
                </tr>
            }
        </tbody>
    </table>

    <h3>Top Agents</h3>
    <table class="data-table">
        <thead>
            <tr>
                <th>Agent</th>
                <th>Calls Handled</th>
                <th>Avg Duration</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in _topAgents)
            {
                <tr>
                    <td>@row.Agent</td>
                    <td>@row.Calls</td>
                    <td>@row.AvgDuration</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private Timer? _timer;
    private bool _showAdvanced;

    private int _originated, _answered, _unanswered, _bridged, _activeNow, _completed;
    private string _answeredPct = "0", _unansweredPct = "0", _bridgedPct = "0";
    private string _avgDuration = "—", _avgWait = "—";

    private List<StateRow> _stateBreakdown = [];
    private List<QueueRow> _topQueues = [];
    private List<AgentRow> _topAgents = [];

    protected override void OnInitialized()
    {
        _timer = new Timer(_ => { Refresh(); InvokeAsync(StateHasChanged); },
            null, TimeSpan.Zero, TimeSpan.FromSeconds(2));
    }

    private void Refresh()
    {
        var calls = CallTracker.AllCalls
            .Where(c => c.ServerId == ServerSvc.SelectedServerId)
            .ToList();

        _originated = calls.Count;
        _answered = calls.Count(WasAnswered);
        _unanswered = _originated - _answered;
        _bridged = calls.Count(c => c.AgentName is not null);

        _answeredPct = _originated > 0 ? ((double)_answered / _originated * 100).ToString("F0") : "0";
        _unansweredPct = _originated > 0 ? ((double)_unanswered / _originated * 100).ToString("F0") : "0";
        _bridgedPct = _answered > 0 ? ((double)_bridged / _answered * 100).ToString("F0") : "0";

        _activeNow = calls.Count(c => c.State != CallFlowState.Completed);
        _completed = calls.Count(c => c.State == CallFlowState.Completed);

        var completedCalls = calls.Where(c => c.State == CallFlowState.Completed).ToList();
        _avgDuration = completedCalls.Count > 0
            ? FormatSeconds((int)completedCalls.Average(c => c.Duration.TotalSeconds))
            : "—";

        var waitTimes = calls
            .Select(c =>
            {
                var join = c.Events.FirstOrDefault(e => e.Type == CallFlowEventType.QueueJoin);
                var connect = c.Events.FirstOrDefault(e => e.Type == CallFlowEventType.AgentConnect);
                return join is not null && connect is not null ? (TimeSpan?)(connect.Timestamp - join.Timestamp) : null;
            })
            .Where(t => t.HasValue)
            .Select(t => t!.Value)
            .ToList();
        _avgWait = waitTimes.Count > 0
            ? FormatSeconds((int)waitTimes.Average(t => t.TotalSeconds))
            : "—";

        if (_showAdvanced)
            RefreshAdvanced(calls);
    }

    private void RefreshAdvanced(List<CallFlow> calls)
    {
        _stateBreakdown = Enum.GetValues<CallFlowState>()
            .Select(s =>
            {
                var count = calls.Count(c => c.State == s);
                return new StateRow
                {
                    State = s,
                    Count = count,
                    Pct = _originated > 0 ? ((double)count / _originated * 100).ToString("F0") : "0"
                };
            })
            .Where(r => r.Count > 0)
            .ToList();

        _topQueues = calls
            .Where(c => c.QueueName is not null)
            .GroupBy(c => c.QueueName!)
            .Select(g =>
            {
                var total = g.Count();
                var ans = g.Count(WasAnswered);
                return new QueueRow
                {
                    Queue = g.Key,
                    Calls = total,
                    Answered = ans,
                    AnswerRate = total > 0 ? ((double)ans / total * 100).ToString("F0") : "0"
                };
            })
            .OrderByDescending(r => r.Calls)
            .Take(10)
            .ToList();

        _topAgents = calls
            .Where(c => c.AgentName is not null)
            .GroupBy(c => c.AgentName!)
            .Select(g => new AgentRow
            {
                Agent = g.Key,
                Calls = g.Count(),
                AvgDuration = FormatSeconds((int)g.Average(c => c.Duration.TotalSeconds))
            })
            .OrderByDescending(r => r.Calls)
            .Take(10)
            .ToList();
    }

    private static bool WasAnswered(CallFlow c) =>
        c.Events.Any(e =>
            e.Type == CallFlowEventType.AgentConnect
            || e.Type == CallFlowEventType.Bridge
            || (e.Type == CallFlowEventType.Answer
                && string.Equals(e.Detail, "ANSWER", StringComparison.OrdinalIgnoreCase)));

    private static string FormatSeconds(int seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return ts.TotalMinutes >= 1 ? $"{(int)ts.TotalMinutes}m{ts.Seconds:D2}s" : $"{ts.Seconds}s";
    }

    public void Dispose() => _timer?.Dispose();

    private sealed class StateRow
    {
        public CallFlowState State { get; init; }
        public int Count { get; init; }
        public string Pct { get; init; } = "0";
    }

    private sealed class QueueRow
    {
        public string Queue { get; init; } = "";
        public int Calls { get; init; }
        public int Answered { get; init; }
        public string AnswerRate { get; init; } = "0";
    }

    private sealed class AgentRow
    {
        public string Agent { get; init; } = "";
        public int Calls { get; init; }
        public string AvgDuration { get; init; } = "—";
    }
}
