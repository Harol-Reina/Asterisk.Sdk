@page "/channels"
@using DashboardExample.Services
@using Asterisk.Sdk.Enums
@using Asterisk.Sdk.Live.Channels
@inject SelectedServerService ServerSvc
@implements IDisposable

<PageTitle>Channels — Asterisk Dashboard</PageTitle>

<h2>Active Channels</h2>

<div class="chip-bar">
    <button class="chip @(_stateFilter is null ? "chip-active" : "")" @onclick="() => _stateFilter = null">All</button>
    <button class="chip @(_stateFilter == ChannelState.Dialing ? "chip-active" : "")" @onclick="() => _stateFilter = ChannelState.Dialing">Dialing</button>
    <button class="chip @(_stateFilter == ChannelState.Ringing ? "chip-active" : "")" @onclick="() => _stateFilter = ChannelState.Ringing">Ringing</button>
    <button class="chip @(_stateFilter == ChannelState.Up ? "chip-active" : "")" @onclick="() => _stateFilter = ChannelState.Up">Up</button>
    <button class="chip @(_stateFilter == ChannelState.Busy ? "chip-active" : "")" @onclick="() => _stateFilter = ChannelState.Busy">Busy</button>
</div>

<table class="data-table">
    <thead>
        <tr>
            <th>UniqueId</th>
            <th>Channel</th>
            <th>State</th>
            <th>CallerID</th>
            <th>Context</th>
            <th>Extension</th>
            <th>Duration</th>
            <th>Linked</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var (serverId, entry) in ServerSvc.GetServers())
        {
            var channels = _stateFilter.HasValue
                ? entry.Server.Channels.GetChannelsByState(_stateFilter.Value)
                : entry.Server.Channels.ActiveChannels;

            foreach (var ch in channels)
            {
                <tr>
                    <td class="mono">@ch.UniqueId</td>
                    <td>@ch.Name</td>
                    <td>
                        <span class="status-dot @GetChannelDotClass(ch.State)"></span>
                        @ch.State
                    </td>
                    <td>@ch.CallerIdNum</td>
                    <td>@ch.Context</td>
                    <td>@ch.Extension</td>
                    <td class="caller-timer">@FormatDuration(DateTimeOffset.UtcNow - ch.CreatedAt)</td>
                    <td>@ch.LinkedChannel?.Name</td>
                </tr>
            }
        }
    </tbody>
</table>

<h3>Originate Call</h3>
<div class="inline-form">
    <input @bind="_originateChannel" placeholder="PJSIP/2000" class="input" />
    <input @bind="_originateContext" placeholder="default" class="input" />
    <input @bind="_originateExtension" placeholder="100" class="input" />
    <input @bind="_originateCallerId" placeholder="CallerID" class="input" />
    <input @bind="_originateTimeout" type="number" placeholder="30" class="input input-sm" />
    <button class="btn btn-blue" @onclick="Originate">Originate</button>
</div>
@if (_originateResult is not null)
{
    <p class="action-result">@_originateResult</p>
}

@code {
    private Timer? _timer;
    private ChannelState? _stateFilter;

    private string _originateChannel = "";
    private string _originateContext = "default";
    private string _originateExtension = "";
    private string _originateCallerId = "";
    private int _originateTimeout = 30;
    private string? _originateResult;

    protected override void OnInitialized()
    {
        _timer = new Timer(_ => InvokeAsync(StateHasChanged),
            null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private async Task Originate()
    {
        if (string.IsNullOrWhiteSpace(_originateChannel))
            return;

        var entry = ServerSvc.GetSelectedServer();
        if (entry is null) return;

        var result = await entry.Server.OriginateAsync(
            _originateChannel,
            _originateContext,
            _originateExtension,
            callerId: string.IsNullOrWhiteSpace(_originateCallerId) ? null : _originateCallerId,
            timeout: TimeSpan.FromSeconds(_originateTimeout));

        _originateResult = result.Success
            ? $"Success — Channel: {result.ChannelId}"
            : $"Failed — {result.Message}";
    }

    private static string GetChannelDotClass(ChannelState state) => state switch
    {
        ChannelState.Up => "dot-green",
        ChannelState.Ringing => "dot-blue",
        ChannelState.Ring => "dot-blue-light",
        ChannelState.Dialing => "dot-yellow",
        ChannelState.Busy => "dot-red",
        ChannelState.Down => "dot-gray",
        _ => "dot-gray-light"
    };

    private static string FormatDuration(TimeSpan ts) =>
        ts.TotalHours >= 1
            ? $"{(int)ts.TotalHours}:{ts.Minutes:D2}:{ts.Seconds:D2}"
            : $"{(int)ts.TotalMinutes}:{ts.Seconds:D2}";

    public void Dispose() => _timer?.Dispose();
}
