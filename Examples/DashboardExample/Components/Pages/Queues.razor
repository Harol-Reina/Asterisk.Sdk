@page "/queues"
@using DashboardExample.Services
@using DashboardExample.Components.Shared
@inject AsteriskMonitorService Monitor
@implements IDisposable

<PageTitle>Queues — Asterisk Dashboard</PageTitle>

<h2>Queues</h2>
<ServerSelector @bind-SelectedServerId="_selectedServer" />

<div class="card-grid">
    @foreach (var (serverId, entry) in GetServers())
    {
        foreach (var queue in entry.Server.Queues.Queues)
        {
            var healthClass = queue.EntryCount switch
            {
                0 when queue.MemberCount == 0 => "health-gray",
                0 => "health-green",
                <= 3 => "health-yellow",
                _ => "health-red"
            };

            <a href="/queue/@serverId/@queue.Name" class="queue-card @healthClass">
                <div class="queue-card-header">
                    <strong>@queue.Name</strong>
                    <span class="badge badge-muted">@serverId</span>
                </div>
                <div class="queue-card-meta">
                    @if (queue.Strategy is not null)
                    {
                        <span>@queue.Strategy</span>
                    }
                </div>
                <div class="queue-card-stats">
                    <div class="stat">
                        <span class="stat-value">@queue.MemberCount</span>
                        <span class="stat-label">Members</span>
                    </div>
                    <div class="stat">
                        <span class="stat-value @(queue.EntryCount > 0 ? "text-red badge-pulse" : "")">@queue.EntryCount</span>
                        <span class="stat-label">Waiting</span>
                    </div>
                    <div class="stat">
                        <span class="stat-value">@queue.Completed</span>
                        <span class="stat-label">Done</span>
                    </div>
                    <div class="stat">
                        <span class="stat-value">@queue.Abandoned</span>
                        <span class="stat-label">Dropped</span>
                    </div>
                </div>
            </a>
        }
    }
</div>

@code {
    private Timer? _timer;
    private string? _selectedServer;

    protected override void OnInitialized()
    {
        _timer = new Timer(_ => InvokeAsync(StateHasChanged),
            null, TimeSpan.Zero, TimeSpan.FromSeconds(2));
    }

    private IEnumerable<KeyValuePair<string, AsteriskMonitorService.ServerEntry>> GetServers() =>
        string.IsNullOrEmpty(_selectedServer)
            ? Monitor.Servers
            : Monitor.Servers.Where(s => s.Key == _selectedServer);

    public void Dispose() => _timer?.Dispose();
}
