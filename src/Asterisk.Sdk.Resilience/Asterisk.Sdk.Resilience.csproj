<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Asterisk.Sdk.Resilience - Composable circuit breaker + retry/backoff + timeout primitives. AOT-safe, zero reflection, TimeProvider-based for testability. No Polly dependency.</Description>
    <PackageTags>asterisk;resilience;circuit-breaker;retry;timeout;sdk</PackageTags>
    <!-- New package — no baseline published yet; skip binary compatibility check -->
    <EnablePackageValidation>false</EnablePackageValidation>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Asterisk.Sdk.Resilience.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>

</Project>
