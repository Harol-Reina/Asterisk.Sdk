<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Description>Asterisk.Sdk.Push.Nats - publishes Push bus events to a NATS subject hierarchy that mirrors the Push topic tree (asterisk.sdk.**). AOT-safe.</Description>
    <PackageTags>asterisk;push;nats;bridge;multi-node;sdk</PackageTags>
    <!-- New package — no baseline published yet; skip binary compatibility check -->
    <EnablePackageValidation>false</EnablePackageValidation>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Asterisk.Sdk.Push.Nats.Tests" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Asterisk.Sdk.Push\Asterisk.Sdk.Push.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="NATS.Client.Core" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>
</Project>
