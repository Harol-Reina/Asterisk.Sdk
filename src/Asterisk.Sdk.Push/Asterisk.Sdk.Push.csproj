<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Description>Asterisk.Sdk.Push - Real-time push primitives: topic hierarchy, subscription management, authorization, in-memory event fan-out. AOT-safe, no aspnetcore dependency.</Description>
    <PackageTags>asterisk;push;sse;realtime;pubsub;sdk</PackageTags>
    <!-- New package — no baseline published yet; skip binary compatibility check -->
    <EnablePackageValidation>false</EnablePackageValidation>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Asterisk.Sdk.Push.Tests" />
    <InternalsVisibleTo Include="Asterisk.Sdk.Push.AspNetCore" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="System.Reactive" />
  </ItemGroup>
</Project>
